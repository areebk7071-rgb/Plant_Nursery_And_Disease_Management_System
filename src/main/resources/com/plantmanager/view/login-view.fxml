<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.plantmanager.controller.LoginController"
           styleClass="login-root"
           prefWidth="480" prefHeight="560">

    <VBox styleClass="login-card" spacing="0" maxWidth="400" alignment="TOP_CENTER">
        <VBox styleClass="login-header" alignment="CENTER" spacing="6">
            <padding>
                <Insets top="28" right="24" bottom="28" left="24"/>
            </padding>
            <Label text="🌿" styleClass="login-icon"/>
            <Label text="Botanical Treatment Advisor" styleClass="login-title"/>
            <Label fx:id="subtitleLabel" text="Sign in to continue" styleClass="login-subtitle"/>
        </VBox>

        <!-- Login Form Container -->
        <VBox fx:id="loginFormBox" spacing="16" alignment="CENTER_LEFT">
            <padding>
                <Insets top="28" right="32" bottom="28" left="32"/>
            </padding>

            <VBox spacing="6">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Enter username" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="login-error" visible="false" managed="false" wrapText="true"/>

            <Button fx:id="loginButton" text="Sign In" onAction="#handleLogin"
                    styleClass="primary-button login-button" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?" styleClass="login-hint"/>
                <Hyperlink text="Sign Up" onAction="#showRegisterForm" style="-fx-text-fill: #2d6a4f; -fx-font-weight: bold;"/>
            </HBox>

        </VBox>

        <!-- Registration Form Container -->
        <VBox fx:id="registerFormBox" spacing="14" alignment="CENTER_LEFT" visible="false" managed="false">
            <padding>
                <Insets top="20" right="32" bottom="28" left="32"/>
            </padding>

            <VBox spacing="4">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="regUsernameField" promptText="Choose a username" styleClass="login-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Display Name" styleClass="field-label"/>
                <TextField fx:id="regDisplayNameField" promptText="Enter your name" styleClass="login-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="regPasswordField" promptText="Create password" styleClass="login-field"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Confirm Password" styleClass="field-label"/>
                <PasswordField fx:id="regConfirmPasswordField" promptText="Confirm password" styleClass="login-field"/>
            </VBox>

            <Label fx:id="regErrorLabel" styleClass="login-error" visible="false" managed="false" wrapText="true"/>

            <Button fx:id="registerButton" text="Create Account" onAction="#handleRegister"
                    styleClass="primary-button login-button" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Already have an account?" styleClass="login-hint"/>
                <Hyperlink text="Sign In" onAction="#showLoginForm" style="-fx-text-fill: #2d6a4f; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
