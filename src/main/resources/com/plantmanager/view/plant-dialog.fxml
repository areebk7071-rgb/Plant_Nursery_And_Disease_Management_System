<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.plantmanager.controller.PlantDialogController"
      spacing="12" prefWidth="540">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Common Fields" styleClass="subsection-title"/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100" prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Species:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="speciesField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Planted Date:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="plantedDatePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="Plant Type" styleClass="subsection-title"/>

    <fx:define>
        <ToggleGroup fx:id="plantTypeGroup"/>
    </fx:define>

    <FlowPane hgap="12" vgap="6">
        <RadioButton fx:id="fruitRadio" text="Fruit" toggleGroup="$plantTypeGroup" selected="true"/>
        <RadioButton fx:id="flowerRadio" text="Flower" toggleGroup="$plantTypeGroup"/>
        <RadioButton fx:id="herbRadio" text="Herb" toggleGroup="$plantTypeGroup"/>
        <RadioButton fx:id="vegetableRadio" text="Vegetable" toggleGroup="$plantTypeGroup"/>
        <RadioButton fx:id="treeRadio" text="Tree" toggleGroup="$plantTypeGroup"/>
        <RadioButton fx:id="vineRadio" text="Vine" toggleGroup="$plantTypeGroup"/>
    </FlowPane>

    <Label text="Secondary Category (optional)" styleClass="subsection-title"/>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <ComboBox fx:id="categoryCombo" prefWidth="250" promptText="None"/>
        <Label text="e.g. a Fruiting Tree = Tree + Fruit" styleClass="chart-hint"/>
    </HBox>

    <Label text="Icon / Photo" styleClass="subsection-title"/>
    <HBox spacing="14" alignment="CENTER_LEFT">
        <ImageView fx:id="iconPreview" fitWidth="64" fitHeight="64" styleClass="icon-preview"/>
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Built-in icon:" styleClass="field-label"/>
            <ComboBox fx:id="iconCombo" maxWidth="Infinity"/>
            <HBox spacing="8">
                <Button text="Upload Photo..." onAction="#handleUploadPhoto" styleClass="secondary-button"/>
                <Button text="Use Icon" onAction="#handleClearPhoto" styleClass="secondary-button"/>
            </HBox>
            <Label fx:id="customPhotoLabel" styleClass="chart-hint" wrapText="true"/>
            <Label text="Photos saved to plant-images/ folder; CSV stores the path only."
                   styleClass="chart-hint" wrapText="true"/>
        </VBox>
    </HBox>

    <!-- Fruit-specific fields -->
    <VBox fx:id="fruitFields" spacing="8">
        <Label text="Fruit Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Expected Yield (kg):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="yieldField" text="0" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Harvest Period:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="harvestPeriodCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
        </GridPane>
    </VBox>

    <!-- Flower-specific fields -->
    <VBox fx:id="flowerFields" spacing="8" visible="false" managed="false">
        <Label text="Flower Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Bloom Color:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="bloomColorCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="Perennial:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <CheckBox fx:id="perennialCheck" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Herb-specific fields -->
    <VBox fx:id="herbFields" spacing="8" visible="false" managed="false">
        <Label text="Herb Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Culinary Use:" GridPane.rowIndex="0" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
            <TextArea fx:id="culinaryUseArea" prefRowCount="3" wrapText="true"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Medicinal:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <CheckBox fx:id="medicinalCheck" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Vegetable-specific fields -->
    <VBox fx:id="vegetableFields" spacing="8" visible="false" managed="false">
        <Label text="Vegetable Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Root Type:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="rootTypeCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="Days to Harvest:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="daysToHarvestField" text="60" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Tree-specific fields -->
    <VBox fx:id="treeFields" spacing="8" visible="false" managed="false">
        <Label text="Tree Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Max Height (m):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="maxHeightField" text="5" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Label text="Canopy Spread (m):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="canopySpreadField" text="3" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Vine-specific fields -->
    <VBox fx:id="vineFields" spacing="8" visible="false" managed="false">
        <Label text="Vine Details" styleClass="subsection-title"/>
        <GridPane hgap="10" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>
            <Label text="Climbing Support:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="climbingSupportCombo" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="Growth Rate:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="growthRateCombo" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
            <Label text="Max Vine Length (m):" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="maxVineLengthField" text="3" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        </GridPane>
    </VBox>

    <Label fx:id="validationLabel" styleClass="validation-label"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save" onAction="#handleSave" defaultButton="true"/>
    </HBox>
</VBox>
