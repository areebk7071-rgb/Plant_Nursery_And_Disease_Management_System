<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.plantmanager.controller.TreatmentDialogController"
            prefWidth="560" prefHeight="620"
            styleClass="treatment-dialog-root">

    <top>
        <VBox styleClass="treatment-dialog-header" spacing="4">
            <padding>
                <Insets top="22" right="24" bottom="22" left="24"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="headerIconLabel" text="💊" styleClass="treatment-header-icon"/>
                <VBox spacing="3">
                    <Label fx:id="diseaseNameLabel" text="Disease Name" styleClass="treatment-header-title"/>
                    <Label fx:id="contextLabel" text="Treatment plan" styleClass="treatment-header-subtitle"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="treatment-scroll">
            <VBox spacing="14">
                <padding>
                    <Insets top="18" right="20" bottom="8" left="20"/>
                </padding>

                <VBox styleClass="treatment-card treatment-card-info" spacing="8">
                    <Label text="Disease Overview" styleClass="treatment-card-title"/>
                    <HBox spacing="8" alignment="TOP_LEFT">
                        <Label text="Symptoms" styleClass="treatment-field-label" minWidth="100"/>
                        <Label fx:id="symptomsLabel" wrapText="true" styleClass="treatment-field-value" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="8" alignment="TOP_LEFT">
                        <Label text="Cause" styleClass="treatment-field-label" minWidth="100"/>
                        <Label fx:id="agentLabel" wrapText="true" styleClass="treatment-field-value" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox styleClass="treatment-card treatment-card-chemical" spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🧪" styleClass="treatment-card-emoji"/>
                        <Label text="Chemical Treatment" styleClass="treatment-card-title"/>
                    </HBox>
                    <Label fx:id="chemicalNameLabel" wrapText="true" styleClass="treatment-highlight"/>
                    <Label text="Application" styleClass="treatment-field-label"/>
                    <Label fx:id="applicationLabel" wrapText="true" styleClass="treatment-field-value"/>
                </VBox>

                <VBox styleClass="treatment-card treatment-card-organic" spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🌿" styleClass="treatment-card-emoji"/>
                        <Label text="Organic Alternative" styleClass="treatment-card-title"/>
                    </HBox>
                    <Label fx:id="organicLabel" wrapText="true" styleClass="treatment-field-value"/>
                </VBox>

                <HBox spacing="14">
                    <VBox styleClass="treatment-card treatment-card-duration" spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="⏱ Recommended Duration" styleClass="treatment-card-title"/>
                        <Label fx:id="durationBadgeLabel" text="14 days" styleClass="treatment-duration-badge"/>
                    </VBox>
                    <VBox fx:id="precautionsCard" styleClass="treatment-card treatment-card-warning" spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="⚠ Precautions" styleClass="treatment-card-title"/>
                        <Label fx:id="precautionsLabel" wrapText="true" styleClass="treatment-field-value"/>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="treatment-dialog-footer">
            <padding>
                <Insets top="14" right="20" bottom="18" left="20"/>
            </padding>
            <Button text="Close" onAction="#handleClose" styleClass="secondary-button"/>
        </HBox>
    </bottom>
</BorderPane>
