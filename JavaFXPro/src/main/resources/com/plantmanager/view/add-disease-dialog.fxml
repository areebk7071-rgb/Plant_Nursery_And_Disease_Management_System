<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.plantmanager.controller.AddDiseaseDialogController"
      spacing="10" prefWidth="460">

    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label text="Add New Disease" styleClass="section-title"/>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Disease Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" promptText="e.g. Downy Mildew"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Symptoms:" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="symptomsArea" prefRowCount="2" wrapText="true"
                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Causative Agent:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="causativeAgentField" promptText="e.g. Fungus, Bacterium, Insect"
                   GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Label text="Treatment Plan" styleClass="subsection-title"/>

    <GridPane hgap="10" vgap="8">
        <columnConstraints>
            <ColumnConstraints minWidth="130" prefWidth="140"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Chemical Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="chemicalNameField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Application Method:" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="applicationMethodArea" prefRowCount="2" wrapText="true"
                  GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Organic Alternative:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="organicAlternativeField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Duration (days):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="durationField" promptText="0 = ongoing" text="21"
                   GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Precautions:" GridPane.rowIndex="4" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="precautionsArea" prefRowCount="2" wrapText="true"
                  GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="validationLabel" styleClass="validation-label"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel"/>
        <Button text="Save Disease" onAction="#handleSave" defaultButton="true"/>
    </HBox>
</VBox>
